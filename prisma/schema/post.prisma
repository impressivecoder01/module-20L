model Post {
    id String @id @default(uuid())
    title String @db.VarChar(266)
    content String @db.Text
    thumbnail String? 
    isFeatured Boolean @default(false)
    status PostStatus @default(PUBLISHED)
    tags String[]
    views Int @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    comments Comment[]

    @@map("posts")
}